<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/socket.io/socket.io.js"></script>
</head>
<body class="bg-slate-100 text-slate-800 min-h-screen">
  <% if (currentUser) { %>
    <div class="flex min-h-screen">
      <aside class="hidden lg:block w-72 bg-slate-900 text-white"><%- include('../partials/sidebar') %></aside>
      <main class="flex-1 p-4 md:p-6"><%- body %></main>
    </div>
  <% } else { %>
    <main><%- body %></main>
  <% } %>
</body>
</html>

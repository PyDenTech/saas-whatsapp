<div class="p-6 border-b border-slate-800">
  <div class="text-xs uppercase tracking-[0.2em] text-slate-400">Tenant</div>
  <div class="font-semibold text-lg mt-1"><%= currentUser.company_name %></div>
  <div class="text-sm text-slate-400"><%= currentUser.full_name %> · <%= currentUser.role %></div>
</div>
<nav class="p-4 space-y-2 text-sm">
  <a href="/dashboard" class="block rounded-xl px-4 py-3 bg-slate-800 hover:bg-slate-700">Dashboard</a>
  <a href="/conversations" class="block rounded-xl px-4 py-3 bg-slate-800 hover:bg-slate-700">Conversas</a>
  <a href="/agents" class="block rounded-xl px-4 py-3 bg-slate-800 hover:bg-slate-700">Atendentes</a>
  <% if (currentUser.role === 'admin') { %><a href="/settings" class="block rounded-xl px-4 py-3 bg-slate-800 hover:bg-slate-700">Configurações</a><% } %>
  <form action="/logout" method="post" class="pt-4">
    <button class="w-full rounded-xl bg-rose-600 px-4 py-3 font-medium">Sair</button>
  </form>
</nav>
